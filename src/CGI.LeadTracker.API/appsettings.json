{
  "ConnectionStrings": {
    "DefaultConnection": "Server=DB_HOST;Port=3306;Database=DB_NAME;User ID=DB_USER;Password=[DB_PASSWORD];SslMode=Preferred;"
  },
  "Database": {
    "MigrateOnStartup": true,
    "SeedOnStartup": true
  },
  "Seed": {
    "AdminName": "Administrador",
    "AdminEmail": "admin@presenca.com.br",
    "AdminPassword": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Secret": "[JWT_SECRET_MINIMO_32_CARACTERES_AQUI]",
    "Issuer": "CGI.LeadTracker",
    "Audience": "CGI.LeadTracker.Client",
    "ExpirationMinutes": "480"
  },
  "LeadSyncSettings": {
    "IntervalMinutes": 60
  },
  "RdStation": {
    "BaseUrl": "https://api.rd.services",
    "ClientId": "[RD_STATION_CLIENT_ID]",
    "ClientSecret": "[RD_STATION_CLIENT_SECRET]",
    "RefreshToken": "[RD_STATION_REFRESH_TOKEN]",
    "SyncLookbackHours": "24",
    "StageMapping": {
      "Lead Recebido": "LeadReceived",
      "Contato Realizado": "ContactMade",
      "Proposta Enviada": "ProposalSent",
      "Contrato Fechado": "ContractClosed",
      "Desqualificado": "Disqualified"
    }
  },
  "Meta": {
    "BaseUrl": "https://graph.facebook.com/v19.0",
    "PixelId": "[META_PIXEL_ID]",
    "AccessToken": "[META_ACCESS_TOKEN]"
  },
  "GoogleAds": {
    "Enabled": false,
    "CustomerId": "[GOOGLE_ADS_CUSTOMER_ID]",
    "LoginCustomerId": "",
    "DeveloperToken": "[GOOGLE_ADS_DEVELOPER_TOKEN]",
    "OAuthClientId": "[GOOGLE_ADS_OAUTH_CLIENT_ID]",
    "OAuthClientSecret": "[GOOGLE_ADS_OAUTH_CLIENT_SECRET]",
    "RefreshToken": "[GOOGLE_ADS_REFRESH_TOKEN]"
  }
}
