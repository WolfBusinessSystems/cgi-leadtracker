{
  "ConnectionStrings": {
    "DefaultConnection": "Server=SEU_SERVIDOR;Database=CGILeadTracker;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Secret": "[JWT_SECRET_MINIMO_32_CARACTERES_AQUI]",
    "Issuer": "CGI.LeadTracker",
    "Audience": "CGI.LeadTracker.Client",
    "ExpirationMinutes": "480"
  },
  "LeadSyncSettings": {
    "IntervalMinutes": 60
  },
  "RdStation": {
    "BaseUrl": "https://api.rd.services",
    "ClientId": "[RD_STATION_CLIENT_ID]",
    "ClientSecret": "[RD_STATION_CLIENT_SECRET]",
    "SyncLookbackHours": "24",
    "StageMapping": {
      "Lead Recebido": "LeadReceived",
      "Contato Realizado": "ContactMade",
      "Proposta Enviada": "ProposalSent",
      "Contrato Fechado": "ContractClosed",
      "Desqualificado": "Disqualified"
    }
  },
  "Meta": {
    "BaseUrl": "https://graph.facebook.com/v19.0",
    "PixelId": "[META_PIXEL_ID]",
    "AccessToken": "[META_ACCESS_TOKEN]"
  },
  "GoogleAds": {
    "Enabled": false
  }
}
