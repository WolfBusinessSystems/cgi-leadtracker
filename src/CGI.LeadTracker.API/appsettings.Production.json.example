// ─────────────────────────────────────────────────────────────────────────────
// TEMPLATE de configuração de PRODUÇÃO.
//
// 1. Copie este arquivo para "appsettings.Production.json" (que é git-ignored)
//    OU forneça cada valor via variável de ambiente (recomendado em servidores).
// 2. Preencha TODOS os segredos. Não deixe placeholders [ENTRE_COLCHETES].
// 3. Remova os comentários ao copiar — JSON puro não aceita "//".
//
// Convenção de variáveis de ambiente (ASP.NET Core): aninhamento vira "__".
//   ConnectionStrings:DefaultConnection  ->  ConnectionStrings__DefaultConnection
//   Auth:Secret                          ->  Auth__Secret
//   Seed:AdminPassword                   ->  Seed__AdminPassword
//   Meta:AccessToken                     ->  Meta__AccessToken
// Variáveis de ambiente têm precedência sobre os arquivos appsettings.
// ─────────────────────────────────────────────────────────────────────────────
{
  "ConnectionStrings": {
    // MySQL de produção. Use um usuário dedicado com permissão só neste banco.
    // SslMode=Required (recomendado) se o servidor tiver TLS; Preferred faz fallback.
    "DefaultConnection": "Server=DB_HOST;Port=3306;Database=DB_NAME;User ID=DB_USER;Password=__SENHA__;SslMode=Required;"
  },

  "Database": {
    // true: a aplicação aplica migrations pendentes no start (deploy simples, 1 instância).
    // false: o schema é gerenciado por um DBA / pipeline (gere o script com
    //        "dotnet ef migrations script --idempotent" e aplique manualmente).
    "MigrateOnStartup": true,
    "SeedOnStartup": true
  },

  "Seed": {
    "AdminName": "Administrador",
    "AdminEmail": "admin@grupopresenca.com.br",
    // OBRIGATÓRIO no primeiro start em produção (senão a aplicação aborta o start).
    // Após o admin existir, este valor é ignorado. Troque a senha pela aplicação depois.
    "AdminPassword": "[DEFINA_UMA_SENHA_FORTE]"
  },

  "Auth": {
    // Mínimo 32 caracteres. Gere com: openssl rand -base64 48
    "Secret": "[JWT_SECRET_MINIMO_32_CARACTERES]",
    "Issuer": "CGI.LeadTracker",
    "Audience": "CGI.LeadTracker.Client",
    "ExpirationMinutes": "480"
  },

  "LeadSyncSettings": {
    "IntervalMinutes": 60
  },

  "RdStation": {
    "BaseUrl": "https://api.rd.services",
    "ClientId": "[RD_STATION_CLIENT_ID]",
    "ClientSecret": "[RD_STATION_CLIENT_SECRET]",
    "RefreshToken": "[RD_STATION_REFRESH_TOKEN]",
    "SyncLookbackHours": "24",
    "StageMapping": {
      "Lead Recebido": "LeadReceived",
      "Contato Realizado": "ContactMade",
      "Proposta Enviada": "ProposalSent",
      "Contrato Fechado": "ContractClosed",
      "Desqualificado": "Disqualified"
    }
  },

  "Meta": {
    "BaseUrl": "https://graph.facebook.com/v19.0",
    "PixelId": "[META_PIXEL_ID]",
    "AccessToken": "[META_ACCESS_TOKEN]"
  },

  "GoogleAds": {
    // Mantenha false até ter as credenciais OAuth e a conta validadas.
    "Enabled": false,
    "CustomerId": "[GOOGLE_ADS_CUSTOMER_ID]",
    "LoginCustomerId": "",
    "DeveloperToken": "[GOOGLE_ADS_DEVELOPER_TOKEN]",
    "OAuthClientId": "[GOOGLE_ADS_OAUTH_CLIENT_ID]",
    "OAuthClientSecret": "[GOOGLE_ADS_OAUTH_CLIENT_SECRET]",
    "RefreshToken": "[GOOGLE_ADS_REFRESH_TOKEN]"
  }
}
